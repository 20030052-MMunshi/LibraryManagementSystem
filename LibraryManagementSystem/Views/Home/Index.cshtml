@{
    ViewBag.Title = "Home";
}

<main>

    <div class="jumbotron text-center">

        <h1>Library Management System</h1>

        <p class="lead">
            This Library Management System is developed using ASP.NET MVC Framework.
            The system helps librarians manage books, members, borrowing records,
            feedback, and user login in an organized and efficient way.
        </p>

        <br />

        <p>
            @Html.ActionLink("Manage Books", "Index", "Books",
                null,
                new { @class = "btn btn-primary btn-lg" })

            @Html.ActionLink("View Members", "Index", "Members",
                null,
                new { @class = "btn btn-success btn-lg" })
        </p>

    </div>

    <!-- Library Profile Section -->

    <div class="card p-4 mb-5 shadow rounded">

        <h2 class="text-center">Library Profile</h2>

        <hr />

        <div class="row">

            <div class="col-md-6">

                <p><strong>Library Name:</strong> Horizon Valley Library</p>

                <p><strong>Location:</strong> Melbourne, Australia</p>

                <p><strong>Operating Hours:</strong> Monday - Saturday | 8:30 AM - 7:00 PM</p>

            </div>

            <div class="col-md-6">

                <p><strong>Contact Details:</strong> +61 3 8456 7821</p>

                <p><strong>Email:</strong> support@horizonlibrary.com</p>

                <p><strong>Services:</strong> Digital Library Access, Book Borrowing, Member Management, Study Rooms</p>

            </div>

        </div>

    </div>

    <!-- Features Section -->

    <div class="row">

        <section class="col-md-4">

            <h2>Book Management</h2>

            <p>
                Users can add, edit, delete, and view books.
                The system also stores information such as title,
                author, genre, ISBN, and availability status.
            </p>

            <p>
                @Html.ActionLink("Books Page", "Index", "Books",
                    null,
                    new { @class = "btn btn-outline-dark" })
            </p>

        </section>

        <section class="col-md-4">

            <h2>Borrow Records</h2>

            <p>
                Borrowing records help the library manage borrowed books,
                due dates, return dates, and member activities.
            </p>

            <p>
                @Html.ActionLink("Borrow Records", "Index", "BorrowRecords",
                    null,
                    new { @class = "btn btn-outline-dark" })
            </p>

        </section>

        <section class="col-md-4">

            <h2>User Login System</h2>

            <p>
                The system includes a simple login and registration feature
                for librarians and members to access the application securely.
            </p>

            <p>
                @Html.ActionLink("Login", "Login", "Home",
                    null,
                    new { @class = "btn btn-outline-dark" })
            </p>

        </section>

    </div>

    <br />

    <!-- Group Details -->

    <h2>Group Details</h2>

    <table class="table table-striped table-bordered">

        <tr>
            <th>Student Name</th>
            <th>Student ID</th>
            <th>Contribution</th>
        </tr>

        <tr>
            <td>Md Siam Munshi</td>
            <td>20030052</td>
            <td>
                Book Management CRUD, validation,
                dropdown implementation, login system,
                GitHub integration and UI improvements.
            </td>
        </tr>

        <tr>
            <td>Roshan Kumar Mahato</td>
            <td>2003337</td>
            <td>Database and Member Management</td>
        </tr>

        <tr>
            <td>Md Amdadul Haque Kawser</td>
            <td>20029397</td>
            <td>Borrow Record Management</td>
        </tr>

        <tr>
            <td>Md Ashraful Islam</td>
            <td>20031587</td>
            <td>
                Feedback System development, testing,
                UI/CSS improvements, homepage customization,
                login integration and GitHub collaboration.
            </td>
        </tr>

    </table>

</main>